---
import Layout from '../layouts/Layout.astro';
import { getTrabajos, getSiteConfig, renderRichText } from '../lib/storyblok';

const sessionCookie = Astro.cookies.get('sg_session');

let accessCode = process.env.ACCESS_CODE || 'sandra2024';
try {
  const config = await getSiteConfig();
  if (config.accessCode) accessCode = config.accessCode;
} catch {}

const isAuthenticated = sessionCookie?.value === accessCode;

if (!isAuthenticated) {
  return Astro.redirect('/lock');
}

const siteConfig = await getSiteConfig();
const heroLine1   = siteConfig.heroLine1   || 'Hola! soy';
const heroLine2   = siteConfig.heroLine2   || 'Sandra González';
const heroLine3   = siteConfig.heroLine3   || 'product designer';
const heroLine4   = renderRichText(siteConfig.heroLine4) || '';
const heroBgImage = siteConfig.heroBgImage || '';
const heroBgColor = siteConfig.heroBgColor || '';

const allTrabajos = await getTrabajos();
const visibles    = allTrabajos.filter((t) => !t.content.draft);
const featured    = visibles.filter((t) => t.content.featured);
const regular     = visibles.filter((t) => !t.content.featured);
---

<Layout title="Sandra González — Trabajos">
  <section class="works">

    <div class="hero" style={[heroBgImage ? `--hero-bg-image: url('${heroBgImage}')` : '', heroBgColor ? `--hero-bg-color: ${heroBgColor}` : ''].filter(Boolean).join(';')}>
      {heroBgImage && <div class="hero-bg-image" aria-hidden="true"></div>}
      <div class="hero-content">
        <p class="hero-line hero-line--1">{heroLine1}</p>
        <p class="hero-line hero-line--2">{heroLine2}</p>
        <p class="hero-line hero-line--3">{heroLine3}</p>
        <div class="hero-line hero-line--4" set:html={heroLine4}></div>
      </div>

      <div class="hero-scroll">
        <svg class="hero-arrow" width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 5v14M5 13l7 7 7-7" stroke="#0F0D0B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>

    {featured.map((t, i) => (
      <a href={`/trabajo/${t.slug}`} class="work-jumbo reveal" style={`--i: ${i}`}>
        <div class="jumbo-image" transition:name={`cover-${t.slug}`}>
          <img
            src={typeof t.content.cover === 'object' ? t.content.cover.filename : t.content.cover}
            alt={t.content.title}
            loading="eager"
          />
          <div class="jumbo-overlay">
            <span class="work-year">{t.content.year}</span>
            <span class="jumbo-cta">Ver proyecto →</span>
          </div>
        </div>
        <div class="jumbo-info">
          <span class="work-category">{t.content.categoria}</span>
          <h2 class="jumbo-title" transition:name={`title-${t.slug}`}>{t.content.title}</h2>
        </div>
      </a>
    ))}

    {regular.length > 0 && (
      <div class="works-grid">
        {regular.map((t, i) => (
          <a href={`/trabajo/${t.slug}`} class="work-card reveal" style={`--i: ${i + featured.length}`}>
            <div class="work-image-wrapper" transition:name={`cover-${t.slug}`}>
              <img
                src={typeof t.content.cover === 'object' ? t.content.cover.filename : t.content.cover}
                alt={t.content.title}
                loading="lazy"
              />
              <div class="work-overlay">
                <span class="work-year">{t.content.year}</span>
                <span class="work-cta">Ver proyecto →</span>
              </div>
            </div>
            <div class="work-info">
              <span class="work-category">{t.content.categoria}</span>
              <h2 class="work-title" transition:name={`title-${t.slug}`}>{t.content.title}</h2>
            </div>
          </a>
        ))}
      </div>
    )}

  </section>
</Layout>

<style>
  .works { display: flex; flex-direction: column; gap: 5rem; }

  .work-jumbo { display: block; text-decoration: none; color: inherit; }

  .jumbo-image {
    position: relative; aspect-ratio: 16/7; overflow: hidden;
    background: var(--bg-card);
  }
  .jumbo-image img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.8s cubic-bezier(0.4,0,0.2,1);
  }
  .work-jumbo:hover .jumbo-image img { transform: scale(1.03); }

  .jumbo-overlay {
    position: absolute; inset: 0; background: var(--overlay-dark);
    display: flex; align-items: flex-end; justify-content: space-between;
    padding: 2rem; opacity: 0; transition: opacity 0.3s ease;
  }
  .work-jumbo:hover .jumbo-overlay { opacity: 1; }
  .jumbo-cta { font-size: 0.75rem; letter-spacing: 0.12em; color: var(--overlay-meta); }

  .jumbo-info {
    margin-top: 1.5rem; display: flex;
    flex-direction: column; gap: 0.4rem;
  }
  .jumbo-title {
    font-family: 'Trocchi', Georgia, serif;
    font-size: clamp(1.8rem,3.5vw,2.8rem); font-weight: 400; line-height: 1.1;
    color: var(--fg); transition: color 0.25s;
  }
  .work-jumbo:hover .jumbo-title { color: var(--accent-warm); }

  .works-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 4rem 3.5rem; }
  @media (max-width: 640px) { .works-grid { grid-template-columns: 1fr; gap: 3rem; } }

  .work-card { text-decoration: none; color: inherit; display: block; }

  .work-image-wrapper {
    position: relative; aspect-ratio: 4/3; overflow: hidden;
    background: var(--bg-card);
  }
  .work-image-wrapper img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.7s cubic-bezier(0.4,0,0.2,1);
  }
  .work-card:hover .work-image-wrapper img { transform: scale(1.04); }

  .work-overlay {
    position: absolute; inset: 0; background: var(--overlay-dark);
    display: flex; align-items: flex-end; justify-content: space-between;
    padding: 1.25rem; opacity: 0; transition: opacity 0.3s ease;
  }
  .work-card:hover .work-overlay { opacity: 1; }

  .work-info { margin-top: 1.1rem; display: flex; flex-direction: column; gap: 0.3rem; }
  .work-title {
    font-family: 'Trocchi', Georgia, serif;
    font-size: clamp(1.2rem,2vw,1.6rem); font-weight: 400; line-height: 1.2;
    color: var(--fg); transition: color 0.25s;
  }
  .work-card:hover .work-title { color: var(--accent-warm); }

  /* ── Hero fullscreen ── */
  .hero {
    position: relative;
    width: 100vw;
    left: 50%;
    transform: translateX(-50%);
    height: 100dvh;
    margin-top: calc(-72px - 3.5rem);
    margin-bottom: 7rem;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    overflow: hidden;
    background: var(--hero-bg-color, var(--bg));
    padding-left: max(2.5rem, calc((100vw - 1400px) / 2));
    padding-right: max(2.5rem, calc((100vw - 1400px) / 2));
    border-bottom: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .hero { margin-top: calc(-60px - 2rem); padding-left: 1.25rem; padding-right: 1.25rem; }
  }

  .hero-content {
    position: relative; z-index: 1;
    text-align: left; max-width: 44rem; width: 100%;
  }

  .hero-bg-image {
    position: absolute; inset: 0;
    background-color: #888ABA;
    background-image: var(--hero-bg-image);
    background-size: auto 100%;
    background-position: right center;
    background-repeat: no-repeat;
    z-index: 0;
  }

  .hero-bg-image::after {
    content: ''; position: absolute; inset: 0;
    background: rgba(247, 244, 238, 0.55);
  }

  .hero-line {
    display: block;
    font-family: 'Trocchi', Georgia, serif;
    font-weight: 400; color: var(--heading-h1);
    opacity: 0; transform: translateY(20px);
    animation: heroFadeUp 1s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  .hero-line--1 {
    font-size: clamp(1.2rem, 2vw, 1.6rem); line-height: 1.2;
    letter-spacing: 0.01em; margin-bottom: 0.4rem;
    color: var(--fg-secondary); animation-delay: 0.2s;
  }
  .hero-line--2 {
    font-size: clamp(3.5rem, 8vw, 7rem); line-height: 1;
    letter-spacing: -0.03em; margin-bottom: 0.5rem;
    color: var(--heading-h1); animation-delay: 0.4s;
  }
  .hero-line--3 {
    font-size: clamp(1.4rem, 3vw, 2.4rem); line-height: 1.2;
    letter-spacing: 0.04em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 2.5rem; animation-delay: 0.6s;
  }
  .hero-line--4 {
    font-size: clamp(0.9rem, 1.4vw, 1.1rem);
    font-family: 'Trocchi', Georgia, serif; font-weight: 400;
    line-height: 1.9; color: var(--fg-muted);
    letter-spacing: 0.01em; animation-delay: 0.8s;
  }
  @keyframes heroFadeUp { to { opacity: 1; transform: translateY(0); } }

  .hero-scroll {
    position: absolute; bottom: 2.5rem; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.6rem;
    z-index: 1; opacity: 0;
    animation: heroFadeUp 1s cubic-bezier(0.4,0,0.2,1) 1.2s forwards;
  }
  .hero-arrow { animation: arrowBounce 2s ease-in-out infinite; }
  @keyframes arrowBounce {
    0%, 100% { transform: translateY(0); opacity: 0.45; }
    50%       { transform: translateY(6px); opacity: 0.8; }
  }

  .work-category { font-size: 0.7rem; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 500; color: var(--accent-sage); opacity: 0.8; }
  .work-year     { font-size: 1.1rem; letter-spacing: 0.08em; font-weight: 300; color: var(--overlay-text); }
  .work-cta      { font-size: 0.75rem; letter-spacing: 0.1em; color: var(--overlay-meta); }

  .reveal {
    opacity: 0; transform: translateY(-48px);
    transition:
      opacity 0.75s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.75s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: calc(var(--i, 0) * 0.08s);
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  const io = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      e.target.classList.toggle('visible', e.isIntersecting);
    }),
    { threshold: 0.08, rootMargin: '0px 0px -60px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
</script>
