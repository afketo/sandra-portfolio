---
import LogoSG from '../components/LogoSG.astro';
import '../styles/global.css';

const hasError = Astro.url.searchParams.get('error') === '1';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sandra González</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Netlify Identity: procesa tokens de invitación y recuperación de contraseña -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body class="lock-body">
    <div class="lock-container">
      <div class="logo-wrapper">
        <LogoSG />
      </div>

      <form method="POST" action="/api/unlock" class="lock-form">
        <input
          type="password"
          name="code"
          placeholder="·····"
          autocomplete="off"
          autofocus
          class:list={['lock-input', hasError && 'lock-input--error']}
        />
        {hasError && <p class="lock-error">Código incorrecto</p>}
        <button type="submit" class="lock-submit">Entrar</button>
      </form>
    </div>

    <script>
      // Si hay un token de invitación o recuperación en la URL,
      // el widget de Netlify Identity lo detecta y abre el modal automáticamente.
      // Una vez que Sandra establece su contraseña, la redirigimos al admin.
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('login', () => {
          window.location.href = '/admin/';
        });
      }
    </script>
  </body>
</html>

<style>
  .lock-body {
    background: #111111;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lock-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  .logo-wrapper {
    transform: scale(2);
  }

  .lock-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .lock-input {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(245, 245, 240, 0.2);
    color: #F5F5F0;
    font-family: 'DM Sans', sans-serif;
    font-size: 1.5rem;
    letter-spacing: 0.5rem;
    text-align: center;
    padding: 0.5rem 1rem;
    width: 14rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .lock-input:focus {
    border-bottom-color: rgba(245, 245, 240, 0.8);
  }

  .lock-input--error {
    border-bottom-color: rgba(255, 100, 100, 0.6);
  }

  .lock-input::placeholder {
    color: rgba(245, 245, 240, 0.2);
    letter-spacing: 0.5rem;
  }

  .lock-error {
    font-size: 0.75rem;
    color: rgba(255, 100, 100, 0.8);
    letter-spacing: 0.05em;
  }

  .lock-submit {
    background: transparent;
    border: 1px solid rgba(245, 245, 240, 0.15);
    color: rgba(245, 245, 240, 0.45);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.6rem 2rem;
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 0.5rem;
  }

  .lock-submit:hover {
    border-color: rgba(245, 245, 240, 0.5);
    color: #F5F5F0;
  }
</style>
