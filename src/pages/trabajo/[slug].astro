---
import Layout from '../../layouts/Layout.astro';
import { getEntry, render } from 'astro:content';

const { slug } = Astro.params;

const trabajo = await getEntry('trabajos', slug!);

if (!trabajo || trabajo.data.draft) {
  return Astro.redirect('/');
}

const { Content } = await render(trabajo);
const { title, categoria, year, cover, images = [], bloques = [] } = trabajo.data;
---

<Layout title={`${title} — Sandra Gonzalez`}>
  <article class="project">

    <!-- Hero -->
    <div class="project-hero reveal">
      <div class="project-meta">
        <span class="project-category">{categoria}</span>
        <span class="project-year">{year}</span>
      </div>
      <h1 class="project-title">{title}</h1>
    </div>

    <!-- Cover -->
    <div class="project-cover reveal reveal-delay-1">
      <img src={cover} alt={title} loading="eager" />
    </div>

    <!-- Cuerpo: bloques o markdown -->
    <div class="project-layout reveal reveal-delay-2">
      <div class="project-body">

        {bloques.length > 0 ? bloques.map((bloque: any) =>
          bloque.type === 'texto' ? (
            <div class="bloque-texto" set:html={bloque.texto} />
          ) : bloque.type === 'imagen' ? (
            <figure class="bloque-imagen">
              <img src={bloque.imagen} alt={bloque.caption ?? ''} loading="lazy" />
              {bloque.caption && <figcaption>{bloque.caption}</figcaption>}
            </figure>
          ) : null
        ) : <Content />}

      </div>

      <aside class="project-sidebar">
        <div class="sidebar-item">
          <span class="sidebar-label">Proyecto</span>
          <span class="sidebar-value">{title}</span>
        </div>
        <div class="sidebar-item">
          <span class="sidebar-label">Disciplina</span>
          <span class="sidebar-value">{categoria}</span>
        </div>
        <div class="sidebar-item">
          <span class="sidebar-label">Año</span>
          <span class="sidebar-value">{year}</span>
        </div>
      </aside>
    </div>

    <!-- Galería extra si existe -->
    {images.length > 0 && (
      <div class="project-gallery reveal">
        {images.map((img: string, i: number) => (
          <figure class={`gallery-item reveal reveal-delay-${(i % 3) + 1}`}>
            <img src={img} alt={`${title} — imagen ${i + 1}`} loading="lazy" />
          </figure>
        ))}
      </div>
    )}

    <div class="project-footer reveal">
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Todos los trabajos
      </a>
    </div>

  </article>
</Layout>

<style>
  .project { max-width: 80rem; margin: 0 auto; }

  /* Hero */
  .project-hero {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid rgba(245,245,240,0.08);
    margin-bottom: 3.5rem;
  }
  .project-meta {
    display: flex; align-items: center; gap: 1.5rem; margin-bottom: 1.5rem;
  }
  .project-category {
    font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(245,245,240,0.45);
  }
  .project-year { font-size: 0.7rem; color: rgba(245,245,240,0.25); }
  .project-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(2.8rem,6vw,5.5rem); font-weight: 400; line-height: 1.05;
    color: #F5F5F0; max-width: 18ch;
  }

  /* Cover */
  .project-cover {
    aspect-ratio: 16/9; overflow: hidden; margin-bottom: 5rem;
    background: rgba(245,245,240,0.04);
  }
  .project-cover img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.4,0,0.2,1);
    display: block;
  }
  .project-cover:hover img { transform: scale(1.02); }

  /* Layout */
  .project-layout {
    display: grid; grid-template-columns: 1fr 18rem;
    gap: 6rem; margin-bottom: 6rem; align-items: start;
  }
  @media (max-width: 900px) {
    .project-layout { grid-template-columns: 1fr; gap: 3rem; }
  }

  /* Body (markdown fallback) */
  .project-body {
    font-size: 1.05rem; line-height: 1.8;
    color: rgba(245,245,240,0.65);
    display: flex; flex-direction: column; gap: 2.5rem;
  }
  .project-body :global(h2) {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.6rem; font-weight: 400; color: #F5F5F0;
    margin-bottom: 0.25rem;
  }
  .project-body :global(p) { margin-bottom: 1.2rem; }
  .project-body :global(ul) { list-style: none; padding: 0; }
  .project-body :global(li) {
    padding-left: 1.25rem; position: relative;
    color: rgba(245,245,240,0.6); margin-bottom: 0.4rem;
  }
  .project-body :global(li)::before {
    content: '—'; position: absolute; left: 0;
    color: rgba(245,245,240,0.25);
  }

  /* Bloques */
  .bloque-texto {
    font-size: 1.05rem; line-height: 1.8;
    color: rgba(245,245,240,0.65);
  }
  .bloque-texto :global(h2) {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.6rem; font-weight: 400; color: #F5F5F0; margin-bottom: 0.75rem;
  }
  .bloque-texto :global(p) { margin-bottom: 1.2rem; }

  .bloque-imagen {
    margin: 0; display: flex; flex-direction: column; gap: 0.75rem;
  }
  .bloque-imagen img {
    width: 100%; display: block; object-fit: cover;
  }
  .bloque-imagen figcaption {
    font-size: 0.75rem; letter-spacing: 0.06em;
    color: rgba(245,245,240,0.3); text-align: center;
  }

  /* Sidebar */
  .project-sidebar {
    position: sticky; top: calc(72px + 2rem);
    display: flex; flex-direction: column;
  }
  .sidebar-item {
    padding: 1.25rem 0; border-top: 1px solid rgba(245,245,240,0.08);
    display: flex; flex-direction: column; gap: 0.4rem;
  }
  .sidebar-item:last-child { border-bottom: 1px solid rgba(245,245,240,0.08); }
  .sidebar-label { font-size: 0.65rem; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(245,245,240,0.3); }
  .sidebar-value { font-size: 0.9rem; color: rgba(245,245,240,0.8); }

  /* Gallery */
  .project-gallery {
    display: grid; grid-template-columns: repeat(2,1fr);
    gap: 1.5rem; margin-bottom: 6rem;
  }
  .project-gallery .gallery-item:first-child { grid-column: 1/-1; }
  .gallery-item { overflow: hidden; background: rgba(245,245,240,0.04); aspect-ratio: 16/9; margin: 0; }
  .gallery-item:first-child { aspect-ratio: 21/9; }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.7s cubic-bezier(0.4,0,0.2,1); }
  .gallery-item:hover img { transform: scale(1.03); }
  @media (max-width: 640px) {
    .project-gallery { grid-template-columns: 1fr; }
    .project-gallery .gallery-item:first-child { grid-column: 1; }
    .gallery-item:first-child { aspect-ratio: 16/9; }
  }

  /* Footer */
  .project-footer { padding-top: 3rem; border-top: 1px solid rgba(245,245,240,0.08); }
  .back-link {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-size: 0.8rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: rgba(245,245,240,0.4); text-decoration: none;
    transition: color 0.2s, gap 0.2s;
  }
  .back-link:hover { color: #F5F5F0; gap: 0.9rem; }

  /* Reveal */
  .reveal {
    opacity: 0; transform: translateY(28px);
    transition: opacity 0.75s cubic-bezier(0.4,0,0.2,1), transform 0.75s cubic-bezier(0.4,0,0.2,1);
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
</style>

<script>
  const io = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
    }),
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
</script>
