---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const trabajos = await getCollection('trabajos', ({ data }) => !data.draft);
  return trabajos.map((trabajo) => ({
    params: { slug: trabajo.id },
    props: { trabajo },
  }));
}

const { trabajo } = Astro.props;
const { Content } = await trabajo.render();
const { title, categoria, year, cover, images = [] } = trabajo.data;
---

<Layout title={`${title} — Sandra Gonzalez`}>
  <article class="project">

    <!-- Hero -->
    <div class="project-hero reveal">
      <div class="project-meta">
        <span class="project-category">{categoria}</span>
        <span class="project-year">{year}</span>
      </div>
      <h1 class="project-title">{title}</h1>
    </div>

    <!-- Cover -->
    <div class="project-cover reveal reveal-delay-1">
      <img src={cover} alt={title} loading="eager" />
    </div>

    <!-- Content + sidebar -->
    <div class="project-layout">
      <div class="project-body reveal reveal-delay-2">
        <Content />
      </div>
      <aside class="project-sidebar reveal reveal-delay-3">
        <div class="sidebar-item">
          <span class="sidebar-label">Proyecto</span>
          <span class="sidebar-value">{title}</span>
        </div>
        <div class="sidebar-item">
          <span class="sidebar-label">Disciplina</span>
          <span class="sidebar-value">{categoria}</span>
        </div>
        <div class="sidebar-item">
          <span class="sidebar-label">Año</span>
          <span class="sidebar-value">{year}</span>
        </div>
      </aside>
    </div>

    <!-- Image gallery -->
    {images.length > 0 && (
      <div class="project-gallery">
        {images.map((img, i) => (
          <div class={`gallery-item reveal reveal-delay-${(i % 3) + 1}`}>
            <img src={img} alt={`${title} — imagen ${i + 1}`} loading="lazy" />
          </div>
        ))}
      </div>
    )}

    <!-- Nav between projects -->
    <div class="project-footer reveal">
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Todos los trabajos
      </a>
    </div>

  </article>
</Layout>

<style>
  /* ── Layout ── */
  .project {
    max-width: 80rem;
    margin: 0 auto;
  }

  /* ── Hero ── */
  .project-hero {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid rgba(245, 245, 240, 0.08);
    margin-bottom: 3.5rem;
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .project-category {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(245, 245, 240, 0.45);
  }

  .project-year {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: rgba(245, 245, 240, 0.25);
  }

  .project-title {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    font-weight: 400;
    line-height: 1.05;
    color: #F5F5F0;
    max-width: 18ch;
  }

  /* ── Cover ── */
  .project-cover {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    margin-bottom: 5rem;
    background: rgba(245, 245, 240, 0.04);
  }

  .project-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .project-cover:hover img {
    transform: scale(1.02);
  }

  /* ── Body + Sidebar ── */
  .project-layout {
    display: grid;
    grid-template-columns: 1fr 18rem;
    gap: 6rem;
    margin-bottom: 6rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .project-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  .project-body {
    font-size: 1.05rem;
    line-height: 1.8;
    color: rgba(245, 245, 240, 0.65);
  }

  .project-body :global(h2) {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 1.6rem;
    font-weight: 400;
    color: #F5F5F0;
    margin: 3rem 0 1rem;
  }

  .project-body :global(p) {
    margin-bottom: 1.4rem;
  }

  .project-body :global(ul) {
    list-style: none;
    padding: 0;
    margin: 1rem 0 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .project-body :global(li) {
    padding-left: 1.25rem;
    position: relative;
    color: rgba(245, 245, 240, 0.6);
  }

  .project-body :global(li)::before {
    content: '—';
    position: absolute;
    left: 0;
    color: rgba(245, 245, 240, 0.25);
  }

  /* ── Sidebar ── */
  .project-sidebar {
    position: sticky;
    top: calc(72px + 2rem);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sidebar-item {
    padding: 1.25rem 0;
    border-top: 1px solid rgba(245, 245, 240, 0.08);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .sidebar-item:last-child {
    border-bottom: 1px solid rgba(245, 245, 240, 0.08);
  }

  .sidebar-label {
    font-size: 0.65rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(245, 245, 240, 0.3);
  }

  .sidebar-value {
    font-size: 0.9rem;
    color: rgba(245, 245, 240, 0.8);
  }

  /* ── Gallery ── */
  .project-gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 6rem;
  }

  .project-gallery .gallery-item:first-child {
    grid-column: 1 / -1;
  }

  .gallery-item {
    overflow: hidden;
    background: rgba(245, 245, 240, 0.04);
    aspect-ratio: 16/9;
  }

  .gallery-item:first-child {
    aspect-ratio: 21/9;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .gallery-item:hover img {
    transform: scale(1.03);
  }

  @media (max-width: 640px) {
    .project-gallery {
      grid-template-columns: 1fr;
    }
    .project-gallery .gallery-item:first-child {
      grid-column: 1;
    }
    .gallery-item:first-child {
      aspect-ratio: 16/9;
    }
  }

  /* ── Footer ── */
  .project-footer {
    padding-top: 3rem;
    border-top: 1px solid rgba(245, 245, 240, 0.08);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(245, 245, 240, 0.4);
    text-decoration: none;
    transition: color 0.2s, gap 0.2s;
  }

  .back-link:hover {
    color: #F5F5F0;
    gap: 0.9rem;
  }

  /* ── Reveal animations ── */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.75s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.75s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
