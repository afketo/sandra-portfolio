---
import Layout from '../../layouts/Layout.astro';
import { getTrabajo, renderRichText } from '../../lib/storyblok';

const { slug } = Astro.params;
const story = await getTrabajo(slug!);

if (!story || story.content.draft) {
  return Astro.redirect('/');
}

const {
  title, categoria, year, cover, coverVideo = '', bloques = [], navColor,
  cliente, rol,
  introTexto, introBgColor, introColorTexto = 'oscuro',
} = story.content;

const coverUrl      = typeof cover === 'object' ? cover.filename : cover;
const hasCoverVideo = Boolean(coverVideo && coverVideo.trim());
const introHtml     = renderRichText(introTexto);
const hasIntro      = introHtml && introHtml.trim() !== '';
const introIsLight  = introColorTexto === 'claro';
const introBg       = introBgColor || (introIsLight ? '#1A1714' : '#F2EDE3');

const bloquesRender = bloques.map((b: any) => {
  const type = b.component || b.type;
  if (type === 'bloque_texto') {
    return { ...b, _type: 'texto', html: renderRichText(b.texto) };
  }
  if (type === 'bloque_imagen') {
    const imgUrl = typeof b.imagen === 'object' ? b.imagen?.filename : b.imagen;
    return { ...b, _type: 'imagen', _imgUrl: imgUrl };
  }
  if (type === 'bloque_columnas') {
    const imgUrl = typeof b.imagen === 'object' ? b.imagen?.filename : b.imagen;
    return { ...b, _type: 'columnas', _imgUrl: imgUrl, html: renderRichText(b.texto) };
  }
  if (type === 'bloque_video') {
    // Normalize YouTube/Vimeo URL to embed
    let embedUrl = '';
    const assetUrl = typeof b.video_asset === 'object' ? b.video_asset?.filename : b.video_asset;
    if (b.video_url) {
      const ytMatch = b.video_url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&\s]+)/);
      const vimeoMatch = b.video_url.match(/vimeo\.com\/(\d+)/);
      if (ytMatch) embedUrl = `https://www.youtube.com/embed/${ytMatch[1]}?rel=0&modestbranding=1`;
      else if (vimeoMatch) embedUrl = `https://player.vimeo.com/video/${vimeoMatch[1]}?title=0&byline=0`;
    }
    return { ...b, _type: 'video', _embedUrl: embedUrl, _assetUrl: assetUrl };
  }
  return { ...b, _type: type };
});
---

<Layout title={`${title} — Sandra González`} navColor={navColor} fullbleed>
  <article class="project">

    <!-- Cover con parallax / video -->
    <div class="project-cover-parallax">
      {hasCoverVideo ? (
        <video
          class="cover-video"
          src={coverVideo}
          autoplay
          loop
          muted
          playsinline
          poster={coverUrl}
        ></video>
      ) : (
        <div class="parallax-img ken-burns" style={`background-image: url('${coverUrl}')`}></div>
      )}
      <div class="cover-meta">
        <span class="cover-cat">{categoria}</span>
        <span class="cover-year">{year}</span>
      </div>
    </div>

    <!-- Sección intro: fullwidth, dos columnas, color personalizable -->
    {hasIntro && (
      <div
        class={`project-intro ${introIsLight ? 'project-intro--light' : 'project-intro--dark'}`}
        style={`background-color: ${introBg}`}
      >
        <div class="intro-inner">
          <div class="intro-texto richtext" set:html={introHtml} />
          <aside class="intro-meta">
            {title && (
              <div class="meta-item">
                <span class="meta-label">Proyecto</span>
                <span class="meta-value">{title}</span>
              </div>
            )}
            {cliente && (
              <div class="meta-item">
                <span class="meta-label">Cliente</span>
                <span class="meta-value">{cliente}</span>
              </div>
            )}
            {rol && (
              <div class="meta-item">
                <span class="meta-label">Rol</span>
                <span class="meta-value">{rol}</span>
              </div>
            )}
            {year && (
              <div class="meta-item">
                <span class="meta-label">Año</span>
                <span class="meta-value">{year}</span>
              </div>
            )}
            {categoria && (
              <div class="meta-item">
                <span class="meta-label">Categoría</span>
                <span class="meta-value">{categoria}</span>
              </div>
            )}
          </aside>
        </div>
      </div>
    )}

    <!-- Bloques de contenido -->
    <div class="project-body">
      {bloquesRender.map((bloque: any, i: number) => (
        <div class="bloque-wrap reveal" style={`--i: ${i}`}>
          {bloque._type === 'texto' ? (
            <div class="bloque-texto richtext" set:html={bloque.html} />
          ) : bloque._type === 'imagen' ? (
            <figure class="bloque-imagen">
              <div class="bloque-imagen-inner">
                <img src={bloque._imgUrl} alt={bloque.caption ?? ''} loading="lazy" />
              </div>
              {bloque.caption && <figcaption>{bloque.caption}</figcaption>}
            </figure>
          ) : bloque._type === 'columnas' ? (
            <div class={`bloque-columnas bloque-columnas--${bloque.layout || 'texto-izq'}`}>
              <div class="col-texto richtext" set:html={bloque.html} />
              <figure class="col-imagen">
                <div class="col-imagen-inner">
                  <img src={bloque._imgUrl} alt={bloque.caption ?? ''} loading="lazy" />
                </div>
                {bloque.caption && <figcaption>{bloque.caption}</figcaption>}
              </figure>
            </div>
          ) : bloque._type === 'video' ? (
            <div class="bloque-video">
              {bloque.titulo && <p class="bloque-video-titulo">{bloque.titulo}</p>}
              {bloque._embedUrl ? (
                <div class="video-embed-wrapper">
                  <iframe
                    src={bloque._embedUrl}
                    title={bloque.titulo || 'Video del proyecto'}
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    loading="lazy"
                  ></iframe>
                </div>
              ) : bloque._assetUrl ? (
                <div class="video-asset-wrapper">
                  <video
                    src={bloque._assetUrl}
                    autoplay={bloque.autoplay}
                    loop={bloque.autoplay}
                    muted={bloque.autoplay}
                    playsinline
                    controls={!bloque.autoplay}
                    loading="lazy"
                  ></video>
                </div>
              ) : null}
            </div>
          ) : null}
        </div>
      ))}
    </div>

    <div class="project-footer reveal">
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Todos los trabajos
      </a>
    </div>

  </article>
</Layout>

<style>
  .project { max-width: 90rem; margin: 0 auto; }

  /* ── Cover Parallax ── */
  .project-cover-parallax {
    position: relative;
    width: 100vw;
    left: 50%;
    transform: translateX(-50%);
    height: 100dvh;
    overflow: hidden;
    margin-bottom: 0;
  }

  .parallax-img {
    position: absolute;
    inset: -15%;
    background-size: cover;
    background-position: center;
    will-change: transform;
  }

  /* Ken Burns: zoom lento + pan sutil — da vida a la imagen sin video */
  @keyframes kenBurns {
    0%   { transform: translateY(var(--py, 0px)) scale(1.08) translateX(0); }
    50%  { transform: translateY(var(--py, 0px)) scale(1.14) translateX(-1.5%); }
    100% { transform: translateY(var(--py, 0px)) scale(1.08) translateX(0); }
  }
  .ken-burns {
    --py: 0px;
    animation: kenBurns 22s ease-in-out infinite;
  }

  /* Video de fondo en el cover */
  .cover-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .cover-meta {
    position: absolute;
    bottom: 2.5rem;
    left: max(2.5rem, calc((100vw - 1400px) / 2));
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    z-index: 2;
  }

  .cover-cat {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.7);
  }

  .cover-year {
    font-family: 'Trocchi', Georgia, serif;
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 400;
    color: rgba(245, 240, 232, 0.9);
    line-height: 1;
  }

  /* Overlay sutil sobre el cover */
  .project-cover-parallax::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(26, 23, 20, 0.25) 0%,
      rgba(26, 23, 20, 0.1) 50%,
      rgba(26, 23, 20, 0.55) 100%
    );
    z-index: 1;
  }

  /* ── Sección intro fullwidth ── */
  .project-intro {
    /* Breakout real: escapa de sg-inner (max-width 1100px) y cubre todo el viewport */
    position: relative;
    width: 100vw;
    left: 50%;
    transform: translateX(-50%);
    margin-bottom: 0;
  }

  .intro-inner {
    /* Padding horizontal alineado con el resto del sitio */
    padding: 5rem max(2.5rem, calc((100vw - 1400px) / 2));
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 6rem;
    align-items: start;
  }

  /* Texto claro sobre fondo oscuro */
  .project-intro--light .intro-texto,
  .project-intro--light .meta-value { color: #F5F0E8; }
  .project-intro--light .meta-label { color: #D4C9B0; }
  .project-intro--light .meta-item  { border-top-color: rgba(245,240,232,0.15); }
  .project-intro--light .meta-item:last-child { border-bottom-color: rgba(245,240,232,0.15); }

  /* Texto oscuro sobre fondo claro */
  .project-intro--dark .intro-texto,
  .project-intro--dark .meta-value { color: #1C1916; }
  .project-intro--dark .meta-label { color: #8B7355; }
  .project-intro--dark .meta-item  { border-top-color: rgba(28,25,22,0.12); }
  .project-intro--dark .meta-item:last-child { border-bottom-color: rgba(28,25,22,0.12); }

  /* Metadatos derecha */
  .intro-meta { padding-top: 0.5rem; }
  .meta-item {
    padding: 1.1rem 0;
    border-top: 1px solid;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .meta-item:last-child { border-bottom: 1px solid; }
  .meta-label {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .meta-value {
    font-family: 'Trocchi', Georgia, serif;
    font-size: 1.05rem;
    line-height: 1.3;
  }

  @media (max-width: 900px) {
    .intro-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 3rem 1.5rem;
    }
  }

  /* ── Bloques ── */
  .project-body {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    margin-top: 6rem;
    margin-bottom: 6rem;
  }

  .bloque-wrap { /* reveal container per bloque */ }

  /* ── Richtext compartido (bloque_texto, intro, columnas) ── */
  .richtext :global(h2) {
    font-family: 'Trocchi', Georgia, serif;
    font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 400;
    margin-bottom: 1rem; line-height: 1.2;
  }
  .richtext :global(h3) {
    font-size: 1.1rem; font-weight: 500; margin-bottom: 0.6rem;
  }
  .richtext :global(p) { font-size: 1.05rem; line-height: 1.85; margin-bottom: 1.1rem; }
  .richtext :global(ul), .richtext :global(ol) { list-style: none; padding: 0; margin-bottom: 1.1rem; }
  .richtext :global(li) {
    font-size: 1.05rem; line-height: 1.7;
    padding-left: 1.5rem; position: relative; margin-bottom: 0.45rem;
  }
  .richtext :global(li)::before { content: '—'; position: absolute; left: 0; color: var(--accent-sage, #6B7A68); }
  .richtext :global(strong) { font-weight: 600; }
  .richtext :global(em) { font-style: italic; }
  .richtext :global(a) { color: var(--accent, #8B7355); text-decoration: underline; text-underline-offset: 3px; }
  .richtext :global(blockquote) {
    border-left: 2px solid var(--accent, #8B7355);
    padding-left: 1.25rem; margin: 1.5rem 0;
    font-style: italic; opacity: 0.8;
  }

  /* Color heredado del contenedor (intro claro/oscuro) */
  .bloque-texto { color: rgba(28,25,22,0.7); }
  .intro-texto  { color: inherit; }

  /* ── Bloque imagen ── */
  .bloque-imagen { margin: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .bloque-imagen-inner {
    overflow: hidden;
    transform-style: preserve-3d;
  }
  .bloque-imagen-inner img {
    width: 100%; display: block;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .bloque-imagen-inner:hover img { transform: scale(1.025); }
  .bloque-imagen figcaption {
    font-size: 0.78rem; letter-spacing: 0.06em;
    color: rgba(28,25,22,0.35); text-align: center;
  }

  /* ── Bloque video ── */
  .bloque-video { display: flex; flex-direction: column; gap: 1rem; }
  .bloque-video-titulo {
    font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(28,25,22,0.4);
  }
  .video-embed-wrapper {
    position: relative; width: 100%; aspect-ratio: 16/9;
    overflow: hidden; background: #1A1714;
  }
  .video-embed-wrapper iframe {
    position: absolute; inset: 0; width: 100%; height: 100%;
    border: none;
  }
  .video-asset-wrapper { width: 100%; }
  .video-asset-wrapper video { width: 100%; display: block; }

  /* ── Bloque columnas ── */
  .bloque-columnas {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* min-width: 0 es crítico — sin esto el contenido desborda el grid */
  .col-texto,
  .col-imagen {
    min-width: 0;
  }

  .bloque-columnas--imagen-izq .col-imagen { order: -1; }

  .col-texto { color: rgba(28,25,22,0.65); overflow-wrap: break-word; word-break: break-word; }
  .col-texto :global(h2) {
    font-family: 'Trocchi', Georgia, serif;
    font-size: clamp(1.2rem, 2vw, 1.7rem); font-weight: 400;
    color: var(--fg); margin-bottom: 0.8rem; line-height: 1.2;
  }
  .col-texto :global(h3) {
    font-size: 1rem; font-weight: 500;
    color: rgba(28,25,22,0.85); margin-bottom: 0.5rem;
  }
  .col-texto :global(p) { font-size: 0.97rem; line-height: 1.8; margin-bottom: 1rem; }
  .col-texto :global(ul), .col-texto :global(ol) { list-style: none; padding: 0; margin-bottom: 1rem; }
  .col-texto :global(li) {
    font-size: 0.97rem; padding-left: 1.25rem;
    position: relative; color: rgba(28,25,22,0.6); margin-bottom: 0.4rem; line-height: 1.7;
  }
  .col-texto :global(li)::before { content: '—'; position: absolute; left: 0; color: var(--accent-sage, #6B7A68); }
  .col-texto :global(strong) { color: var(--fg); font-weight: 500; }

  .col-imagen { margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .col-imagen-inner {
    overflow: hidden;
    transform-style: preserve-3d;
  }
  .col-imagen-inner img {
    width: 100%;
    height: auto;
    max-height: 520px;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .col-imagen-inner:hover img { transform: scale(1.03); }
  .col-imagen figcaption {
    font-size: 0.75rem; letter-spacing: 0.06em;
    color: rgba(28,25,22,0.35); text-align: center;
  }

  @media (max-width: 700px) {
    .bloque-columnas { grid-template-columns: 1fr; gap: 2rem; }
    .bloque-columnas--imagen-izq .col-imagen { order: 0; }
    .col-imagen img { max-height: 320px; }
  }

  /* ── Footer ── */
  .project-footer { padding-top: 3rem; border-top: 1px solid rgba(28,25,22,0.1); }
  .back-link {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(28,25,22,0.35); text-decoration: none; transition: color 0.2s, gap 0.2s;
  }
  .back-link:hover { color: var(--accent-sage, #6B7A68); gap: 0.9rem; }

  /* ── Reveal scroll ── */
  .reveal {
    opacity: 0;
    transform: translateY(32px);
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: calc(var(--i, 0) * 0.07s);
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  // Reveal individual on scroll — each bloque animates independently
  const io = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        io.unobserve(e.target);
      }
    }),
    { threshold: 0.06, rootMargin: '0px 0px -60px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

  // Parallax suave en el cover (solo si hay imagen, no video)
  const parallaxEl = document.querySelector('.parallax-img') as HTMLElement | null;
  if (parallaxEl) {
    const coverEl = parallaxEl.closest('.project-cover-parallax') as HTMLElement | null;
    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        if (!coverEl) { ticking = false; return; }
        const rect = coverEl.getBoundingClientRect();
        if (rect.bottom < 0 || rect.top > window.innerHeight) { ticking = false; return; }
        const progress = -rect.top / window.innerHeight;
        // Combine with Ken Burns: only add translateY, let CSS animation handle scale/xy
        parallaxEl.style.setProperty('--py', `${progress * 80}px`);
        ticking = false;
      });
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
