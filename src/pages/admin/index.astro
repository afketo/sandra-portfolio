<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — Sandra Gonzalez</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=DM+Serif+Display&display=swap" rel="stylesheet" />
    <style>
      html, body { background: #0d0d0d !important; margin: 0; }
    </style>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <script src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>

    <script>
      // Netlify Identity redirect
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', function(user) {
          if (!user) {
            window.netlifyIdentity.on('login', function() {
              document.location.href = '/admin/';
            });
          }
        });
      }

      // Inyectar CSS oscuro DESPUÉS de que Decap renderice (styled-components gana cascada si se carga antes)
      function injectDarkTheme() {
        var style = document.createElement('style');
        style.textContent = `
          /* Fondo general */
          body, #nc-root, [class*="App__"] { background: #0d0d0d !important; color: #F5F5F0 !important; }

          /* Cabecera */
          header, [class*="Header"], [class*="Toolbar"] {
            background: #161616 !important;
            border-bottom: 1px solid rgba(245,245,240,0.08) !important;
            box-shadow: none !important;
          }

          /* Sidebar / colección */
          [class*="CollectionPage"], [class*="Sidebar"], nav[class*="Nav"] {
            background: #111 !important;
            border-right: 1px solid rgba(245,245,240,0.08) !important;
          }

          /* Inputs, textareas, selects */
          input, textarea, select, [class*="Input"], [class*="TextInput"], [class*="Select"] {
            background: #1a1a1a !important;
            color: #F5F5F0 !important;
            border-color: rgba(245,245,240,0.12) !important;
          }
          input:focus, textarea:focus, select:focus {
            border-color: rgba(245,245,240,0.35) !important;
            outline: none !important;
          }

          /* Labels */
          label, [class*="Label"] { color: rgba(245,245,240,0.55) !important; font-size: 0.72rem !important; letter-spacing: 0.12em !important; text-transform: uppercase !important; }

          /* Botones */
          button[class*="primary"], [class*="Button"][class*="primary"] {
            background: #F5F5F0 !important; color: #111 !important; border: none !important;
          }
          button, [class*="Button"] {
            background: rgba(245,245,240,0.07) !important;
            color: #F5F5F0 !important;
            border: 1px solid rgba(245,245,240,0.1) !important;
            border-radius: 4px !important;
          }

          /* Cards de la lista de entradas */
          [class*="ListCard"], [class*="EntryCard"] {
            background: #161616 !important;
            border: 1px solid rgba(245,245,240,0.07) !important;
          }

          /* Markdown editor */
          [class*="EditorControl"], [class*="RawEditor"] {
            background: #1a1a1a !important;
            color: #F5F5F0 !important;
          }

          /* Scrollbar */
          * { scrollbar-color: rgba(245,245,240,0.15) transparent; }
        `;
        document.head.appendChild(style);
      }

      // Registrar preview template y estilos cuando CMS esté listo
      function setupCMS() {
        if (!window.CMS) return;

        // Inyectar tema oscuro ahora que Decap ya cargó su CSS
        injectDarkTheme();

        // Estilos en el iframe de preview
        CMS.registerPreviewStyle('/admin/admin.css');

        // Preview visual de proyectos
        var h = window.h;
        CMS.registerPreviewTemplate('trabajos', function(props) {
          var entry    = props.entry;
          var title    = entry.getIn(['data', 'title'])    || 'Sin título';
          var categoria = entry.getIn(['data', 'categoria']) || '';
          var year     = entry.getIn(['data', 'year'])     || '';
          var cover    = entry.getIn(['data', 'cover'])    || '';
          var featured = entry.getIn(['data', 'featured']) || false;

          return h('div', { style: { background:'#111', color:'#F5F5F0', fontFamily:"'DM Sans',sans-serif", minHeight:'100vh', padding:'2rem' } },

            featured && h('div', { style: { display:'inline-block', fontSize:'0.65rem', letterSpacing:'.15em', textTransform:'uppercase', background:'rgba(201,185,154,.15)', color:'#c9b99a', border:'1px solid rgba(201,185,154,.3)', padding:'.3rem .75rem', borderRadius:'4px', marginBottom:'1.5rem' } }, '⭐ Proyecto Destacado'),

            h('p', { style: { fontSize:'.65rem', letterSpacing:'.15em', textTransform:'uppercase', color:'rgba(245,245,240,.4)', marginBottom:'.75rem' } }, categoria + ' · ' + year),

            h('h1', { style: { fontFamily:"'DM Serif Display',Georgia,serif", fontSize:'clamp(2rem,6vw,3.5rem)', fontWeight:'400', lineHeight:'1.05', marginBottom:'2rem', color:'#F5F5F0' } }, title),

            cover && h('div', { style: { aspectRatio:'16/9', overflow:'hidden', marginBottom:'1.5rem' } },
              h('img', { src: cover, alt: title, style: { width:'100%', height:'100%', objectFit:'cover', display:'block' } })
            ),

            h('p', { style: { fontSize:'.75rem', color:'rgba(245,245,240,.4)', marginTop:'1rem' } }, 'Vista previa — los bloques de contenido se muestran en el sitio')
          );
        });
      }

      // Ejecutar cuando Decap esté disponible
      if (window.CMS) {
        setupCMS();
      } else {
        document.addEventListener('DOMContentLoaded', function() {
          var tries = 0;
          var interval = setInterval(function() {
            if (window.CMS || ++tries > 20) {
              clearInterval(interval);
              setupCMS();
            }
          }, 300);
        });
      }
    </script>
  </body>
</html>
