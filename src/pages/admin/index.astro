<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — Sandra González</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=DM+Serif+Display&display=swap" rel="stylesheet" />
    <style>
      html, body { background: #0d0d0d !important; margin: 0; }
    </style>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <script src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>

    <script>
      // Netlify Identity redirect
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', function(user) {
          if (!user) {
            window.netlifyIdentity.on('login', function() {
              document.location.href = '/admin/';
            });
          }
        });
      }

      // Inyectar CSS oscuro — solo selectores de elementos HTML nativos (Decap usa styled-components con clases hashed)
      function injectDarkTheme() {
        var style = document.createElement('style');
        style.id = 'sg-dark-theme';
        style.textContent = `
          html, body { background: #0d0d0d !important; color: #F5F5F0 !important; font-family: 'Trocchi', Georgia, serif !important; }
          #nc-root { background: #0d0d0d !important; }

          /* Todos los divs con fondo blanco/gris claro → oscuro */
          #nc-root div { color: #F5F5F0; }

          /* Cabecera top */
          #nc-root header { background: #161616 !important; border-bottom: 1px solid rgba(245,245,240,0.08) !important; box-shadow: none !important; }
          #nc-root header * { color: #F5F5F0 !important; }
          #nc-root header a { color: rgba(245,245,240,0.7) !important; text-decoration: none !important; }
          #nc-root header a:hover { color: #F5F5F0 !important; }
          #nc-root header button { background: transparent !important; border: 1px solid rgba(245,245,240,0.15) !important; color: #F5F5F0 !important; border-radius: 4px !important; cursor: pointer !important; }

          /* Nav lateral */
          #nc-root nav { background: #111111 !important; border-right: 1px solid rgba(245,245,240,0.07) !important; }
          #nc-root nav a { color: rgba(245,245,240,0.5) !important; }
          #nc-root nav a:hover, #nc-root nav a[class*="active"] { color: #F5F5F0 !important; background: rgba(245,245,240,0.05) !important; }

          /* Área principal */
          #nc-root main { background: #0d0d0d !important; }

          /* Todas las secciones y paneles */
          #nc-root section { background: #0d0d0d !important; }

          /* Inputs, textareas, selects */
          #nc-root input, #nc-root textarea, #nc-root select {
            background: #1a1a1a !important;
            color: #F5F5F0 !important;
            border: 1px solid rgba(245,245,240,0.12) !important;
            border-radius: 4px !important;
          }
          #nc-root input:focus, #nc-root textarea:focus, #nc-root select:focus {
            border-color: rgba(245,245,240,0.4) !important;
            outline: none !important;
          }
          #nc-root input::placeholder, #nc-root textarea::placeholder { color: rgba(245,245,240,0.25) !important; }

          /* Labels */
          #nc-root label { color: rgba(245,245,240,0.45) !important; font-size: 0.7rem !important; letter-spacing: 0.1em !important; text-transform: uppercase !important; }

          /* Botones genéricos */
          #nc-root button {
            background: rgba(245,245,240,0.06) !important;
            color: #F5F5F0 !important;
            border: 1px solid rgba(245,245,240,0.1) !important;
            border-radius: 4px !important;
            cursor: pointer !important;
          }
          #nc-root button:hover { background: rgba(245,245,240,0.12) !important; }

          /* Botón "Publicar" / primario — suele ser el último botón destacado */
          #nc-root header button:last-child,
          #nc-root button[type="submit"] {
            background: #F5F5F0 !important;
            color: #111 !important;
            border: none !important;
            font-weight: 500 !important;
          }

          /* Listas de entradas — cards */
          #nc-root ul { list-style: none !important; }
          #nc-root ul li { background: #161616 !important; border: 1px solid rgba(245,245,240,0.06) !important; border-radius: 4px !important; margin-bottom: 0.5rem !important; }
          #nc-root ul li a { color: #F5F5F0 !important; }
          #nc-root ul li:hover { border-color: rgba(245,245,240,0.15) !important; background: #1a1a1a !important; }

          /* Texto general */
          #nc-root p, #nc-root span, #nc-root h1, #nc-root h2, #nc-root h3, #nc-root h4 { color: #F5F5F0 !important; }

          /* Separadores */
          #nc-root hr { border-color: rgba(245,245,240,0.08) !important; }

          /* Scrollbar */
          * { scrollbar-width: thin; scrollbar-color: rgba(245,245,240,0.12) transparent; }
        `;
        // Eliminar inyección previa si existe
        var prev = document.getElementById('sg-dark-theme');
        if (prev) prev.remove();
        document.head.appendChild(style);
      }

      // Registrar preview template y estilos cuando CMS esté listo
      function setupCMS() {
        if (!window.CMS) return;

        // Inyectar tema oscuro ahora que Decap ya cargó su CSS
        injectDarkTheme();

        // Estilos en el iframe de preview
        CMS.registerPreviewStyle('/admin/admin.css');

        // Preview visual de proyectos
        var h = window.h;
        CMS.registerPreviewTemplate('trabajos', function(props) {
          var entry    = props.entry;
          var title    = entry.getIn(['data', 'title'])    || 'Sin título';
          var categoria = entry.getIn(['data', 'categoria']) || '';
          var year     = entry.getIn(['data', 'year'])     || '';
          var cover    = entry.getIn(['data', 'cover'])    || '';
          var featured = entry.getIn(['data', 'featured']) || false;

          return h('div', { style: { background:'#111', color:'#F5F5F0', fontFamily:"'DM Sans',sans-serif", minHeight:'100vh', padding:'2rem' } },

            featured && h('div', { style: { display:'inline-block', fontSize:'0.65rem', letterSpacing:'.15em', textTransform:'uppercase', background:'rgba(201,185,154,.15)', color:'#c9b99a', border:'1px solid rgba(201,185,154,.3)', padding:'.3rem .75rem', borderRadius:'4px', marginBottom:'1.5rem' } }, '⭐ Proyecto Destacado'),

            h('p', { style: { fontSize:'.65rem', letterSpacing:'.15em', textTransform:'uppercase', color:'rgba(245,245,240,.4)', marginBottom:'.75rem' } }, categoria + ' · ' + year),

            h('h1', { style: { fontFamily:"'DM Serif Display',Georgia,serif", fontSize:'clamp(2rem,6vw,3.5rem)', fontWeight:'400', lineHeight:'1.05', marginBottom:'2rem', color:'#F5F5F0' } }, title),

            cover && h('div', { style: { aspectRatio:'16/9', overflow:'hidden', marginBottom:'1.5rem' } },
              h('img', { src: cover, alt: title, style: { width:'100%', height:'100%', objectFit:'cover', display:'block' } })
            ),

            h('p', { style: { fontSize:'.75rem', color:'rgba(245,245,240,.4)', marginTop:'1rem' } }, 'Vista previa — los bloques de contenido se muestran en el sitio')
          );
        });
      }

      // Ejecutar cuando Decap esté disponible
      if (window.CMS) {
        setupCMS();
      } else {
        document.addEventListener('DOMContentLoaded', function() {
          var tries = 0;
          var interval = setInterval(function() {
            if (window.CMS || ++tries > 20) {
              clearInterval(interval);
              setupCMS();
            }
          }, 300);
        });
      }
    </script>
  </body>
</html>
