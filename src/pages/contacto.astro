---
import Layout from '../layouts/Layout.astro';
import { getSiteConfig } from '../lib/storyblok';

const site = await getSiteConfig();
const email        = site.email        || '';
const instagram    = site.instagram    || '';
const linkedin     = site.linkedin     || '';
const behance      = site.behance      || '';
const contactIntro = site.contactIntro || '¿Tienes un proyecto en mente? Cuéntame.';
---

<Layout title="Sandra González — Contacto">
  <div class="contact-wrapper">
    <h1>Contacto</h1>
    <p class="contact-intro">{contactIntro}</p>

    {email && (
      <a href={`mailto:${email}`} class="contact-email">{email}</a>
    )}

    <div class="contact-socials">
      {instagram && (
        <a href={instagram} target="_blank" rel="noopener" class="social-link">Instagram</a>
      )}
      {linkedin && (
        <a href={linkedin} target="_blank" rel="noopener" class="social-link">LinkedIn</a>
      )}
      {behance && (
        <a href={behance} target="_blank" rel="noopener" class="social-link">Behance</a>
      )}
    </div>
  </div>
</Layout>

<style>
  .contact-wrapper { max-width: 48rem; padding-top: 4rem; }
  h1 {
    font-family: 'Trocchi', Georgia, serif;
    font-size: clamp(3.5rem, 8vw, 7rem); font-weight: 400;
    line-height: 1; color: var(--fg); margin-bottom: 2rem;
  }
  .contact-intro { font-size: 1.1rem; color: var(--fg-muted); margin-bottom: 3rem; }
  .contact-email {
    display: block; font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    color: var(--fg); text-decoration: none;
    border-bottom: 1px solid var(--border); padding-bottom: 0.5rem;
    margin-bottom: 4rem; transition: border-color 0.2s; width: fit-content;
  }
  .contact-email:hover { border-color: var(--border-strong); }
  .contact-socials { display: flex; gap: 2.5rem; }
  .social-link {
    font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--fg-secondary); text-decoration: none; transition: color 0.2s;
  }
  .social-link:hover { color: var(--fg); }
</style>
