  }

  .footer-name {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    color: rgba(245, 245, 240, 0.35);
  }

  .footer-year {
    font-size: 0.8rem;
    color: rgba(245, 245, 240, 0.2);
    letter-spacing: 0.04em;
  }

  .footer-linkedin {
    color: rgba(245, 245, 240, 0.35);
    display: flex;
    align-items: center;
