---

<a href="/" aria-label="Sandra González — Inicio" class="logo-sg">
  <svg
    width="52"
    height="52"
    viewBox="0 0 40 40"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <!-- S -->
    <path
      class="sg-path sg-s"
      d="M18 8C13 8 9 11 9 15C9 19 12 21 16 22C20 23 23 24.5 23 28C23 31.5 20 34 16 34C12 34 9 32 8 29"
      stroke="#F5F5F0"
      stroke-width="1.5"
      stroke-linecap="round"
    />
    <!-- G -->
    <path
      class="sg-path sg-g"
      d="M32 14C29 11 24 11 21 14C18 17 18 23 21 26C24 29 29 29 32 26V21H28"
      stroke="#F5F5F0"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </svg>
  <span class="logo-name">Sandra González</span>
</a>

<style>
  .logo-sg {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .logo-name {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(245, 245, 240, 0.6);
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    .logo-name {
      display: none;
    }
  }

  .sg-path {
    stroke-dasharray: 120;
    stroke-dashoffset: 120;
    animation: draw 1.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .sg-s { animation-delay: 0s; }
  .sg-g { animation-delay: 0.4s; }

  @keyframes draw {
    to { stroke-dashoffset: 0; }
  }
</style>
