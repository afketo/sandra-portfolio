---
import LogoSG from './LogoSG.astro';

const navLinks = [
  { href: '/', label: 'Trabajos' },
  { href: '/servicios', label: 'Servicios' },
  { href: '/sobre-mi', label: 'Sobre mí' },
  { href: '/contacto', label: 'Contacto' },
];

const currentPath = Astro.url.pathname;
---

<header class="sg-header">
  <div class="sg-header-inner">
    <LogoSG />
    <nav class="sg-nav">
      <ul>
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={currentPath === href ? 'active' : ''}
            >
              <span class="nav-label">{label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .sg-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(247, 244, 238, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-subtle);
    transition: background 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .sg-header-inner {
    position: relative;
    display: flex;
    align-items: center;
    padding: 0 2rem;
    height: 72px;
  }

  .sg-nav {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  @media (max-width: 768px) {
    .sg-header-inner {
      padding: 0 1.25rem;
      height: 60px;
    }
    .sg-nav {
      position: static;
      transform: none;
      margin-left: auto;
    }
  }

  .sg-nav ul {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sg-nav a {
    font-family: 'Trocchi', Georgia, serif;
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--fg-secondary);
    text-decoration: none;
    padding: 0.45rem 0.85rem;
    border-radius: 2rem;
    position: relative;
    display: inline-flex;
    align-items: center;
    overflow: hidden;
    transition: color 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .sg-nav a:hover {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }

  .sg-nav a.active {
    color: var(--accent);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }

  .nav-label {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 600px) {
    .sg-nav ul {
      gap: 0;
    }

    .sg-nav a {
      font-size: 0.78rem;
      padding: 0.4rem 0.6rem;
    }
  }
</style>
