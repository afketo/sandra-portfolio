---
import LogoSG from './LogoSG.astro';

const navLinks = [
  { href: '/', label: 'Trabajos' },
  { href: '/servicios', label: 'Servicios' },
  { href: '/sobre-mi', label: 'Sobre mí' },
  { href: '/contacto', label: 'Contacto' },
];

const currentPath = Astro.url.pathname;
---

<header class="sg-header">
  <div class="sg-header-inner">
    <LogoSG />
    <nav class="sg-nav">
      <ul>
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={currentPath === href ? 'active' : ''}
            >
              <span class="nav-label">{label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .sg-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(17, 17, 17, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(245, 245, 240, 0.07);
  }

  .sg-header-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4rem;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 72px;
  }

  @media (max-width: 768px) {
    .sg-header-inner {
      padding: 0 1.25rem;
      height: 60px;
      gap: 2rem;
    }
  }

  .sg-nav ul {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sg-nav a {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: rgba(245, 245, 240, 0.4);
    text-decoration: none;
    padding: 0.45rem 0.85rem;
    border-radius: 2rem;
    position: relative;
    display: inline-flex;
    align-items: center;
    overflow: hidden;
    transition: color 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Fondo pill animado */
  .sg-nav a::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(245, 245, 240, 0.07);
    border-radius: 2rem;
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .sg-nav a:hover {
    color: #F5F5F0;
  }

  .sg-nav a:hover::before {
    opacity: 1;
    transform: scale(1);
  }

  .sg-nav a.active {
    color: #F5F5F0;
  }

  .sg-nav a.active::before {
    opacity: 1;
    transform: scale(1);
    background: rgba(245, 245, 240, 0.1);
  }

  .nav-label {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 600px) {
    .sg-nav ul {
      gap: 0;
    }

    .sg-nav a {
      font-size: 0.78rem;
      padding: 0.4rem 0.6rem;
    }
  }
</style>
