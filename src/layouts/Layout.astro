---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  navColor?: string;
  fullbleed?: boolean;
}

const {
  title = 'Sandra González — Diseñadora UI/UX',
  description = 'Portfolio de Sandra González, diseñadora UI/UX especializada en experiencias digitales.',
  navColor,
  fullbleed = false,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ViewTransitions />
    {navColor && (
      <style set:html={`:root { --nav-color: ${navColor}; }`} />
    )}
    <style>
      .sg-main {
        padding-top: calc(72px + 3.5rem);
        padding-left: 2rem;
        padding-right: 2rem;
        padding-bottom: 6rem;
        min-height: 100dvh;
      }

      .sg-main--fullbleed {
        padding-top: 72px;
        padding-left: 0;
        padding-right: 0;
      }

      .sg-main--fullbleed .sg-inner {
        padding-left: 2rem;
        padding-right: 2rem;
      }

      .sg-inner {
        max-width: 1400px;
        margin: 0 auto;
      }

      @media (max-width: 768px) {
        .sg-main {
          padding-top: calc(60px + 2rem);
          padding-left: 1.25rem;
          padding-right: 1.25rem;
          padding-bottom: 3rem;
        }
        .sg-main--fullbleed {
          padding-top: 60px;
        }
        .sg-main--fullbleed .sg-inner {
          padding-left: 1.25rem;
          padding-right: 1.25rem;
        }
      }
    </style>
  </head>
  <body>
    <Nav />
    <main class={fullbleed ? 'sg-main sg-main--fullbleed' : 'sg-main'}>
      <div class="sg-inner">
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>
